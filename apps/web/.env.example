# Heather is local-only by default.
# Paid providers are blocked unless this is explicitly set to true.
HEATHER_ALLOW_PAID_API=false

# Optional local no-credit model endpoint.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1

# Optional paid provider, used only when settings and HEATHER_ALLOW_PAID_API=true allow it.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
