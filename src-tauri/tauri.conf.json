{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Heather AI Assistant",
  "version": "0.1.0",
  "identifier": "com.heather.aiassistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../apps/web/.next"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Heather AI Assistant",
        "width": 1440,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
