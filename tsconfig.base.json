{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@heather/core": ["packages/core/src/index.ts"],
      "@heather/ai": ["packages/ai/src/index.ts"],
      "@heather/db": ["packages/db/src/index.ts"],
      "@heather/platform": ["packages/platform/src/index.ts"]
    }
  }
}
