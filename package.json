{
  "name": "heather-ai-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Heather AI Assistant monorepo for a modular personal assistant web app and future desktop shell.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @heather/web",
    "build": "npm run build -w @heather/web",
    "lint": "npm run lint -w @heather/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build",
    "tauri:info": "npx tauri info"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1"
  }
}
